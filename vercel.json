{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "public/images/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "public/storage/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, proxy-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_KEY": "base64:9O5NSi5uo4rbc7NTyGQr6xACebIqeTHbZQDNu2SQfMs=",
    "APP_DEBUG": "false",
    "APP_URL": "https://website-administrasi-ormawa.vercel.app",

    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp",

    "CACHE_STORE": "array",
    "CACHE_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "DB_CONNECTION": "pgsql",
    "DB_HOST": "aws-1-ap-northeast-1.pooler.supabase.com",
    "DB_PORT": "6543",
    "DB_DATABASE": "postgres",
    "DB_USERNAME": "postgres.padtmphepnycyxsdbxjt",
    "DB_PASSWORD": "fUWlGMczNcB9tvcN",
    "DB_SSLMODE": "require",
    "QUEUE_CONNECTION": "sync",
    "FILESYSTEM_DISK": "local",
    "SESSION_DRIVER": "cookie",
    "SESSION_LIFETIME": "120",
    "SESSION_ENCRYPT": "true",
    "SESSION_PATH": "/",
    "SESSION_SECURE_COOKIE": "true",
    "SESSION_HTTP_ONLY": "true",
    "SESSION_SAME_SITE": "lax"
  }
}
